---
import MenuHambur from "./MenuHambur.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { MENU } from "@/utils/data.ts";

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header class="fixed top-0 left-0 w-full z-50 h-17 flex items-center justify-between px-4 md:px-6
  bg-bg-base/80 backdrop-blur-xl border-b border-border-default"
>

  <!-- Logo -->
  <a
    href="/"
    class="text-sm font-bold tracking-widest uppercase text-text-muted hover:text-text-primary transition-colors duration-200"
  >
    jhorky.dev
  </a>

  <!-- Nav desktop -->
  <nav class="hidden md:flex items-center gap-1 p-1 rounded-xl bg-accent-bg border border-border-default">
    {
      MENU.map((item) => {
        const active = isActive(item.href);
        return (
          <a
            href={item.href}
            class={`nav-item px-5 py-2 text-sm font-medium rounded-lg transition-all duration-200 border
              ${active
                ? "text-accent-text bg-accent-bg border-accent-border shadow-[inset_0_1px_0_var(--color-accent-border)]"
                : "text-text-secondary border-transparent hover:text-text-primary hover:bg-bg-hover"
              }`}
          >
            {item.name}
          </a>
        );
      })
    }
  </nav>

  <!-- Toggle + hamburguesa -->
  <div class="flex items-center gap-2">
    <ThemeToggle />
    <div class="block md:hidden">
      <MenuHambur />
    </div>
  </div>

</header>