---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import ReactIcon from "../icons/ReactIcon.astro";
import NodeIcon from "../icons/NodeIcon.astro";
import SupabaseIcon from "../icons/SupabaseIcon.astro";
import GithubIcon from "../icons/GithubIcon.astro";
import { SquareArrowOutUpRight } from "@lucide/astro";
import TailwindIcon from "../icons/TailwindIcon.astro";
import AndroidIcon from "../icons/AndroidIcon.astro";
import AngularIcon from "../icons/AngularIcon.astro";
import AppleIcon from "../icons/AppleIcon.astro";
import AstroIcon from "../icons/AstroIcon.astro";
import BootstrapIcon from "../icons/BootstrapIcon.astro";
import BriefCaseIcon from "../icons/BriefCaseIcon.astro";
import CloudinaryIcon from "../icons/CloudinaryIcon.astro";
import CSharpIcon from "../icons/CSharpIcon.astro";
import CypressIcon from "../icons/CypressIcon.astro";
import DjangoIcon from "../icons/DjangoIcon.astro";
import DockerIcon from "../icons/DockerIcon.astro";
import EmailIcon from "../icons/EmailIcon.astro";
import ExpoIcon from "../icons/ExpoIcon.astro";
import ExpressIcon from "../icons/ExpressIcon.astro";
import FirebaseIcon from "../icons/FirebaseIcon.astro";
import GmailIcon from "../icons/GmailIcon.astro";
import GoogleDriveIcon from "../icons/GoogleDriveIcon.astro";
import GoogleIcon from "../icons/GoogleIcon.astro";
import JavaIcon from "../icons/JavaIcon.astro";
import JavaScriptIcon from "../icons/JavaScriptIcon.astro";
import JWTIcon from "../icons/JWTIcon.astro";
import LaravelIcon from "../icons/LaravelIcon.astro";
import LinkedinIcon from "../icons/LinkedinIcon.astro";
import MaterialUIcon from "../icons/MaterialUIcon.astro";
import MongoDBIcon from "../icons/MongoDBIcon.astro";
import MercadoPagoIcon from "../icons/MercadoPagoIcon.astro";
import MySQLIcon from "../icons/MySQLIcon.astro";
import NestIcon from "../icons/NestIcon.astro";
import NextIcon from "../icons/NextIcon.astro";
import PaypalIcon from "../icons/PaypalIcon.astro";
import PhpIcon from "../icons/PhpIcon.astro";
import PhytonIcon from "../icons/PhytonIcon.astro";
import PostgreSQLIcon from "../icons/PostgreSQLIcon.astro";
import ReactQueryIcon from "../icons/ReactQueryIcon.astro";
import SpotifyIcon from "../icons/SpotifyIcon.astro";
import SequelizeIcon from "../icons/SequelizeIcon.astro";
import SpringIcon from '../icons/SpringIcon.astro';
import SqlServerIcon from "../icons/SqlServerIcon.astro";
import StrapiIcon from "../icons/StrapiIcon.astro";
import StripeIcon from "../icons/StripeIcon.astro";
import TanStackIcon from "../icons/TanStackIcon.astro";
import TypeScriptIcon from "../icons/TypeScriptIcon.astro";
import VueIcon from "../icons/VueIcon.astro";
import WordpressIcon from "../icons/WordpressIcon.astro";
import YoutubeIcon from "../icons/YoutubeIcon.astro";

type TechName = "React" | "Node" | "Supabase" | "Tailwind" | "Android" | "Angular" | "Apple" | "Astro" | "Bootstrap" | "BriefCase" | "Cloudinary" | "CSharp"
| "Cypress" | "Django" | "Docker" | "Email" | "Expo" | "Express" | "Firebase" | "GitHub" | "Gmail" | "GoogleDrive" | "Google" | "Java"
| "JavaScript" | "JWT" | "Laravel" | "Linkedin" | "MaterialUI" | "MercadoPago" | "MongoDB" | "MySQL" | "Nest" | "Next" | "Paypal" | "PHP"
| "Phyton" | "PostgreSQL" | "ReactQuery" | "Sequelize" | "Spotify" | "Spring" | "SQLServer" | "Strapi" | "Stripe" | "TankStack" | "TypeScript"
| "Vue" | "Wordpress" | "Youtube";

interface CardProps {
  title: string;
  image: string;
  description: string;
  techs?: TechName[];
  children?: any;
  urlRepo?: string;
  demo?: string;
}

const { title, image, description, techs = [], children, urlRepo, demo } = Astro.props as CardProps;

const icons: Record<TechName, AstroComponentFactory> = {
  React: ReactIcon, Node: NodeIcon, Supabase: SupabaseIcon, Tailwind: TailwindIcon,
  Android: AndroidIcon, Angular: AngularIcon, Apple: AppleIcon, Astro: AstroIcon,
  Bootstrap: BootstrapIcon, BriefCase: BriefCaseIcon, Cloudinary: CloudinaryIcon,
  CSharp: CSharpIcon, Cypress: CypressIcon, Django: DjangoIcon, Docker: DockerIcon,
  Email: EmailIcon, Expo: ExpoIcon, Express: ExpressIcon, Firebase: FirebaseIcon,
  GitHub: GithubIcon, Gmail: GmailIcon, GoogleDrive: GoogleDriveIcon, Google: GoogleIcon,
  Java: JavaIcon, JavaScript: JavaScriptIcon, JWT: JWTIcon, Laravel: LaravelIcon,
  Linkedin: LinkedinIcon, MaterialUI: MaterialUIcon, MercadoPago: MercadoPagoIcon,
  MongoDB: MongoDBIcon, MySQL: MySQLIcon, Nest: NestIcon, Next: NextIcon,
  Paypal: PaypalIcon, PHP: PhpIcon, Phyton: PhytonIcon, PostgreSQL: PostgreSQLIcon,
  ReactQuery: ReactQueryIcon, Sequelize: SequelizeIcon, Spotify: SpotifyIcon,
  Spring: SpringIcon, SQLServer: SqlServerIcon, Strapi: StrapiIcon, Stripe: StripeIcon,
  TankStack: TanStackIcon, TypeScript: TypeScriptIcon, Vue: VueIcon,
  Wordpress: WordpressIcon, Youtube: YoutubeIcon,
};
---

<article class="card-project group relative flex flex-col rounded-xl overflow-hidden
  bg-bg-panel border border-border-default
  transition-all duration-300 hover:-translate-y-1">

  <!-- Imagen -->
  <div class="relative overflow-hidden aspect-[16/9]">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-bg-base via-transparent to-transparent opacity-60"></div>

    <!-- Botones flotantes (desktop hover) -->
    <div class="absolute top-3 right-3 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
      {urlRepo && (
        <a href={urlRepo} target="_blank" rel="noopener noreferrer" aria-label="Ver repositorio"
          class="btn-overlay flex items-center justify-center size-8 rounded-lg backdrop-blur-sm
            bg-bg-base/80 border border-border-default text-text-secondary transition-all duration-200">
          <GithubIcon />
        </a>
      )}
      {demo && (
        <a href={demo} target="_blank" rel="noopener noreferrer" aria-label="Ver demo"
          class="btn-overlay flex items-center justify-center size-8 rounded-lg backdrop-blur-sm
            bg-bg-base/80 border border-border-default text-text-secondary transition-all duration-200">
          <SquareArrowOutUpRight class="size-4" />
        </a>
      )}
    </div>
  </div>

  <!-- Contenido -->
  <div class="flex flex-col flex-1 p-5 gap-3">

    <!-- Título + botones mobile -->
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-text-primary font-semibold text-base leading-snug">{title}</h3>
      <div class="flex gap-1.5 flex-shrink-0 md:hidden">
        {urlRepo && (
          <a href={urlRepo} target="_blank" rel="noopener noreferrer"
            class="btn-overlay flex items-center justify-center size-7 rounded-lg
              bg-bg-panel border border-border-default text-text-secondary transition-colors">
            <GithubIcon />
          </a>
        )}
        {demo && (
          <a href={demo} target="_blank" rel="noopener noreferrer"
            class="btn-overlay flex items-center justify-center size-7 rounded-lg
              bg-bg-panel border border-border-default text-text-secondary transition-colors">
            <SquareArrowOutUpRight class="size-3.5" />
          </a>
        )}
      </div>
    </div>

    <!-- Descripción -->
    <p class="text-text-secondary text-xs leading-relaxed line-clamp-3 flex-1">
      {description}
    </p>

    <!-- Techs -->
    {techs.length > 0 && (
      <div class="flex flex-wrap gap-1.5 pt-1 border-t border-border-subtle">
        {techs.map((tech) => {
          const IconComponent = icons[tech];
          return (
            <span class="tech-pill flex items-center gap-1 px-2 py-1 rounded-md text-[11px] font-medium
              transition-all duration-200
              bg-bg-panel text-text-secondary border border-border-default">
              {IconComponent && (
                <span class="size-3 flex items-center justify-center shrink-0">
                  <IconComponent class="w-full h-full" />
                </span>
              )}
              {tech}
            </span>
          );
        })}
      </div>
    )}

    {children}
  </div>
</article>

<style>
  .card-project:hover {
    border-color: var(--color-accent-border);
    box-shadow: 0 8px 32px var(--color-accent-bg);
  }
  .btn-overlay:hover {
    color: var(--color-accent-text);
    border-color: var(--color-accent-border);
  }
  .tech-pill:hover {
    color: var(--color-accent-text);
    border-color: var(--color-accent-border);
    background: var(--color-accent-bg);
  }
</style>