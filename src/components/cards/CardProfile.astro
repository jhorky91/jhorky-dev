---
import { SKILLS } from "@/utils/data";
import ButtonDownloadCv from "../buttons/buttonDownloadCv.astro";
import IconArrowDownload from "../icons/IconArrowDownload.astro";
import { Github, Linkedin, Twitter, Youtube } from "@lucide/astro";
---

<section id="sobre-mi" class="scroll-mt-[80px] max-w-3xl mx-auto">

  <!-- Hero -->
  <div class="flex flex-col items-center text-center gap-4 pt-6 pb-10">

    <!-- Foto -->
    <div class="relative">
      <div class="size-28 rounded-full overflow-hidden outline outline-2 outline-offset-4 outline-accent-border transition-all duration-300">
        <img
          src="/foto_cv.jpg"
          alt="Foto de Jhorky Escalante"
          class="w-full h-full object-cover"
        />
      </div>
      <span class="absolute bottom-1 right-1 size-4 rounded-full block outline outline-2 outline-bg-base bg-success-text"></span>
    </div>

    <!-- Subtítulo y nombre -->
    <div class="flex flex-col gap-1">
      <p class="text-sm font-medium tracking-widest uppercase text-accent-text">
        Analista & Desarrollador Frontend
      </p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-text-primary">
        Hola, soy Jhorky <span class="inline-block">👋</span>
      </h1>
    </div>

    <!-- Badge disponible -->
    <div class="flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-medium
      bg-success-bg border border-success-border text-success-text transition-colors duration-300">
      <span class="size-1.5 rounded-full animate-pulse bg-success-text"></span>
      Disponible para trabajar
    </div>

    <!-- Redes sociales -->
    <div class="flex items-center gap-2">
      <a href="https://github.com/jhorky91/" target="_blank" rel="noopener noreferrer" aria-label="GitHub"
        class="social-link flex items-center justify-center size-8 rounded-lg transition-all duration-200
          bg-bg-panel border border-border-default text-text-secondary">
        <Github size={15} />
      </a>
      <a href="https://www.linkedin.com/in/jhorkyescalante/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
        class="social-link flex items-center justify-center size-8 rounded-lg transition-all duration-200
          bg-bg-panel border border-border-default text-text-secondary">
        <Linkedin size={15} />
      </a>
      <a href="https://x.com/JhorkyDev" target="_blank" rel="noopener noreferrer" aria-label="Twitter"
        class="social-link flex items-center justify-center size-8 rounded-lg transition-all duration-200
          bg-bg-panel border border-border-default text-text-secondary">
        <Twitter size={15} />
      </a>
      <a href="https://www.youtube.com/@jhorky91" target="_blank" rel="noopener noreferrer" aria-label="YouTube"
        class="social-link flex items-center justify-center size-8 rounded-lg transition-all duration-200
          bg-bg-panel border border-border-default text-text-secondary">
        <Youtube size={15} />
      </a>
    </div>

    <!-- Divisor -->
    <div class="w-16 h-px my-1" style="background: linear-gradient(to right, transparent, var(--color-accent-border), transparent);"></div>

    <!-- Bio -->
    <div class="text-left flex flex-col gap-4 max-w-2xl">
      <p class="text-sm md:text-base leading-relaxed text-text-secondary">
        Soy
        <span class="font-medium text-text-primary">Analista Funcional</span>
        con más de
        <span class="font-medium text-text-primary">3 años de experiencia</span>
        trabajando junto a equipos de desarrollo, colaborando en la identificación y resolución de
        problemas, optimización de procesos y análisis de datos.
      </p>
      <p class="text-sm md:text-base leading-relaxed text-text-muted">
        En paralelo, me formé en desarrollo web creando proyectos propios con
        <span class="font-medium text-accent-text">React, Node.js, Express y Supabase</span>.
        Busco mi primer oportunidad como desarrollador web para aportar valor desde el primer día.
      </p>
    </div>

    <!-- CV -->
    <div class="mt-2">
      <ButtonDownloadCv
        label="Descargar CV"
        href="https://drive.google.com/uc?export=download&id=17ah2VNPX6366sdDIkCWpuG0h7wY1Wqvu"
      >
        <IconArrowDownload slot="icon" />
      </ButtonDownloadCv>
    </div>
  </div>

  <!-- Skills -->
  <div class="py-8 border-t border-border-subtle">
    <div class="flex items-center gap-3 mb-6">
      <div class="w-1 h-5 rounded-full bg-accent-solid"></div>
      <h2 class="text-lg font-semibold text-text-primary">Mis Skills</h2>
    </div>

    <div class="relative w-full overflow-hidden">
      <div class="skills-fade-left absolute left-0 top-0 h-full w-16 z-10 pointer-events-none"></div>
      <div class="skills-fade-right absolute right-0 top-0 h-full w-16 z-10 pointer-events-none"></div>
      <div class="flex gap-3 skills-track">
        {
          [...SKILLS, ...SKILLS].map((tech) => (
            <span class="skill-pill flex-shrink-0 px-3 py-1.5 rounded-md text-xs font-medium
              transition-all duration-200 cursor-default whitespace-nowrap
              bg-bg-panel text-text-secondary border border-border-default">
              {tech}
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Quote -->
  <div class="py-8 border-t border-border-subtle">
    <blockquote class="pl-5 border-l-2 border-accent-border">
      <p class="text-sm md:text-base italic leading-relaxed text-text-muted">
        "La tecnología es el puente entre lo posible y lo extraordinario."
      </p>
    </blockquote>
  </div>

</section>

<style>
  .skills-track {
    animation: scrollX 28s linear infinite;
    width: max-content;
  }
  .skills-track:hover {
    animation-play-state: paused;
  }
  @keyframes scrollX {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .skill-pill:hover {
    color: var(--color-accent-text);
    border-color: var(--color-accent-border);
    background: var(--color-accent-bg);
  }
  .social-link:hover {
    color: var(--color-accent-text);
    border-color: var(--color-accent-border);
    background: var(--color-accent-bg);
  }
</style>