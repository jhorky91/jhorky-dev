---
import { X } from "@lucide/astro";
import { MENU } from "@/utils/data.ts";

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}
---

<div class="relative z-50">

  <!-- Botón hamburguesa -->
  <button
    id="hamburBtnOpen"
    aria-label="Abrir menú"
    aria-expanded="false"
    class="hambur-btn flex flex-col justify-center gap-[5px] w-10 h-10 p-2 rounded-lg transition-colors duration-200 focus:outline-none"
  >
    <span id="hLine1" class="block w-5 h-0.5 rounded-full transition-all duration-300 origin-center bg-text-secondary"></span>
    <span id="hLine2" class="block w-5 h-0.5 rounded-full transition-all duration-300 origin-center bg-text-secondary"></span>
    <span id="hLine3" class="block w-3.5 h-0.5 rounded-full transition-all duration-300 origin-center bg-accent-solid"></span>
  </button>

  <!-- Overlay -->
  <div
    id="menuOverlay"
    class="fixed inset-0 z-30 opacity-0 pointer-events-none transition-opacity duration-300"
    style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);"
  ></div>

  <!-- Panel -->
  <div
    id="menuMobilePanel"
    role="dialog"
    aria-modal="true"
    class="fixed top-0 left-0 h-screen w-[280px] z-40 -translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] flex flex-col overflow-hidden
      bg-bg-base border-r border-border-default"
  >
    <!-- Borde derecho decorativo con acento -->
    <div class="absolute top-0 right-0 h-full w-px pointer-events-none"
      style="background: linear-gradient(to bottom, transparent, var(--color-accent-border) 30%, var(--color-accent-border) 70%, transparent);">
    </div>

    <!-- Header del panel -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-border-default">
      <div class="flex items-center gap-2.5">
        <div class="size-7 rounded-lg flex items-center justify-center bg-accent-bg border border-accent-border">
          <div class="size-2 rounded-full bg-accent-solid"></div>
        </div>
        <a href="/" class="text-sm font-bold tracking-widest uppercase text-text-primary">
          jhorky.dev
        </a>
      </div>
      <button
        id="hamburBtnClose"
        aria-label="Cerrar menú"
        class="menu-close-btn flex items-center justify-center size-8 rounded-lg transition-all duration-200 cursor-pointer text-text-secondary"
      >
        <X size={16} stroke-width={2.5} />
      </button>
    </div>

    <!-- Navegación -->
    <nav class="flex flex-col px-3 py-4 flex-1 gap-1">
      <p class="text-[10px] font-semibold uppercase tracking-widest px-3 mb-2 text-text-muted">
        Navegación
      </p>
      {
        MENU.map((item) => {
          const active = isActive(item.href);
          return (
            <a
              href={item.href}
              class={`relative flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 border
                ${active
                  ? "text-accent-text bg-accent-bg border-accent-border"
                  : "menu-link text-text-secondary border-transparent"
                }`}
            >
              <span class={`flex items-center justify-center size-8 rounded-md flex-shrink-0 transition-all duration-200
                ${active
                  ? "bg-accent-bg text-accent-text border border-accent-border"
                  : "menu-icon-wrap bg-bg-panel border border-border-default text-text-muted"
                }`}
              >
                <item.icon size={15} stroke-width={2} />
              </span>
              <span>{item.name}</span>
              {active && (
                <span class="ml-auto size-1.5 rounded-full animate-pulse bg-accent-solid flex-shrink-0"></span>
              )}
            </a>
          );
        })
      }
    </nav>

    <!-- Footer -->
    <div class="px-5 py-4 border-t border-border-subtle">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="size-1.5 rounded-full animate-pulse bg-success-text"></span>
          <span class="text-xs text-text-muted">Disponible</span>
        </div>
        <span class="text-xs text-text-muted">v1.0.0</span>
      </div>
    </div>

  </div>
</div>

<style>
  .hambur-btn:hover {
    background: var(--color-bg-hover);
  }
  .menu-close-btn:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-hover);
  }
  .menu-link:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-hover);
  }
  .menu-link:hover .menu-icon-wrap {
    color: var(--color-text-secondary);
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const btnOpen  = document.getElementById("hamburBtnOpen");
    const btnClose = document.getElementById("hamburBtnClose");
    const panel    = document.getElementById("menuMobilePanel");
    const overlay  = document.getElementById("menuOverlay");
    const line1    = document.getElementById("hLine1");
    const line2    = document.getElementById("hLine2");
    const line3    = document.getElementById("hLine3");

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      panel?.classList.replace("-translate-x-full", "translate-x-0");
      overlay?.classList.remove("opacity-0", "pointer-events-none");
      overlay?.classList.add("opacity-100");
      document.body.classList.add("overflow-hidden");
      btnOpen?.setAttribute("aria-expanded", "true");
      line1?.classList.add("rotate-45", "translate-y-[7px]");
      line2?.classList.add("opacity-0", "scale-x-0");
      line3?.classList.add("-rotate-45", "-translate-y-[7px]", "w-5");
      line3?.classList.remove("w-3.5");
    }

    function closeMenu() {
      isOpen = false;
      panel?.classList.replace("translate-x-0", "-translate-x-full");
      overlay?.classList.add("opacity-0", "pointer-events-none");
      overlay?.classList.remove("opacity-100");
      document.body.classList.remove("overflow-hidden");
      btnOpen?.setAttribute("aria-expanded", "false");
      line1?.classList.remove("rotate-45", "translate-y-[7px]");
      line2?.classList.remove("opacity-0", "scale-x-0");
      line3?.classList.remove("-rotate-45", "-translate-y-[7px]", "w-5");
      line3?.classList.add("w-3.5");
    }

    btnOpen?.addEventListener("click",  () => isOpen ? closeMenu() : openMenu());
    btnClose?.addEventListener("click", closeMenu);
    overlay?.addEventListener("click",  closeMenu);
    document.addEventListener("keydown", (e) => e.key === "Escape" && isOpen && closeMenu());
  });
</script>