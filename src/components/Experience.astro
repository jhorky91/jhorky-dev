---
import { EXPERIENCE } from "@/utils/data.ts";
import { Briefcase } from "@lucide/astro";
---

<section class="max-w-2xl mx-auto py-8 px-4">

  <!-- Encabezado -->
  <div class="mb-10 flex flex-col gap-3">
    <div class="flex items-center gap-3">
      <div class="w-1 h-6 rounded-full bg-accent-solid"></div>
      <span class="text-sm font-medium tracking-widest uppercase text-accent-text">Trayectoria</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-text-primary">
      Experiencia Laboral
    </h1>
    <p class="text-base leading-relaxed max-w-lg text-text-secondary">
      Más de 3 años colaborando con equipos de desarrollo en empresas de tecnología, telecomunicaciones y consultoría IT.
    </p>
  </div>

  <!-- Timeline -->
  <ol class="relative flex flex-col gap-0">
    {
      EXPERIENCE.map((experience, index) => (
        <li class="relative flex gap-6 group">

          <!-- Dot + línea -->
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="flex items-center justify-center size-9 rounded-full z-10 mt-1
              bg-accent-bg border border-accent-border text-accent-text">
              <Briefcase size={16} stroke-width={2} />
            </div>
            {index !== EXPERIENCE.length - 1 && (
              <div class="w-px flex-1 mt-2 min-h-[2rem]"
                style="background: linear-gradient(to bottom, var(--color-accent-border), transparent);">
              </div>
            )}
          </div>

          <!-- Contenido -->
          <div class={`flex-1 ${index === EXPERIENCE.length - 1 ? "pb-0" : "pb-10"}`}>
            <div class="exp-card p-5 rounded-xl border transition-all duration-200
              bg-bg-panel border-border-default">

              <!-- Header -->
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                <div>
                  <h3 class="font-semibold text-base leading-snug text-text-primary">
                    {experience.role}
                  </h3>
                  <span class="inline-flex items-center mt-1 px-2.5 py-0.5 rounded-md text-xs font-medium
                    bg-accent-bg text-accent-text border border-accent-border">
                    {experience.company}
                  </span>
                </div>
                <time class="text-xs font-medium whitespace-nowrap mt-0.5 flex-shrink-0 text-text-muted">
                  {experience.date}
                </time>
              </div>

              <!-- Tareas -->
              <ul class="flex flex-col gap-2 mt-3 pt-3 border-t border-border-subtle">
                {experience.description.map((item) => (
                  <li class="flex items-start gap-2.5 text-sm leading-relaxed text-text-secondary">
                    <span class="size-1.5 rounded-full flex-shrink-0 mt-[7px] bg-accent-solid opacity-60"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

        </li>
      ))
    }
  </ol>

</section>

<style>
  .exp-card:hover {
    border-color: var(--color-accent-border);
    background: var(--color-bg-panel);
  }
</style>