---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
import "@fontsource-variable/onest";
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Jhorky Escalante - @jhorky91" />
    <meta name="keywords" content="Jhorky Escalante, Analista Funcional, Desarrollador Web, Astro, Tailwind, Supabase, Express, JavaScript, TypeScript, React, Node, PostgreSQL, MySQL, Oracle, SQL Server, MongoDB, Linux, Figma, PostMan, Git, Azure DevOps, Metodologías ágiles, Cypress" />
    <meta name="application-name" content="Portafolio Jhorky Escalante" />
    <meta name="robots" content="index, follow" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@jhorky91" />
    <meta name="twitter:creator" content="@jhorky91" />
    <meta property="og:url" content="https://jhorky.dev" />
    <meta property="og:title" content="Portafolio Jhorky Escalante" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/foto_cv.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Portafolio Jhorky Escalante" />

    <!-- 1. Anti-flash: aplica el tema antes de pintar -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("jhorky-theme");
        const preferLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        const theme = saved ?? (preferLight ? "light" : "dark");
        if (theme === "light") document.documentElement.classList.add("light");
      })();
    </script>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Jhorky Escalante",
        "url": "https://jhorky.dev",
        "sameAs": [
          "https://github.com/jhorky91",
          "https://www.linkedin.com/in/jhorkyescalante",
          "https://x.com/JhorkyDev",
          "https://www.youtube.com/@jhorky91"
        ],
        "jobTitle": "Analista Funcional y Desarrollador Web",
        "worksFor": {
          "@type": "Organization",
          "name": "Freelance / Proyectos propios"
        }
      }
    </script>

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <title>
      {title ? `${title} | Jhorky Escalante` : "Jhorky Escalante | Portafolio"}
    </title>

    <ClientRouter />
  </head>

  <body class="h-screen flex flex-col overflow-hidden bg-bg-base text-text-primary">

    <div
      class="absolute inset-0 -z-10 h-screen w-full transition-all duration-500"
      style="background: var(--gradient-page);"
      transition:persist
    ></div>

    <Header transition:persist />

    <main class="flex-1 overflow-y-auto px-5 py-4 pt-[80px]" transition:animate="fade">
      <slot />
    </main>

  </body>
</html>

<!-- 2. Script global del tema — is:inline para que persista con View Transitions -->
<script is:inline>
  const STORAGE_KEY = "jhorky-theme";

  function getTheme() {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved === "light" || saved === "dark") return saved;
    return window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
  }

  function applyTheme(theme) {
    const html = document.documentElement;
    const iconSun  = document.getElementById("icon-sun");
    const iconMoon = document.getElementById("icon-moon");

    if (theme === "light") {
      html.classList.add("light");
      iconSun?.classList.add("hidden");
      iconMoon?.classList.remove("hidden");
    } else {
      html.classList.remove("light");
      iconSun?.classList.remove("hidden");
      iconMoon?.classList.add("hidden");
    }
    localStorage.setItem(STORAGE_KEY, theme);
  }

  function initToggle() {
    const toggle = document.getElementById("theme-toggle");
    if (!toggle) return;

    // Sincronizar íconos con el tema actual
    applyTheme(getTheme());

    // Remover listener anterior si existe para no acumularlos
    const oldHandler = toggle._themeHandler;
    if (oldHandler) toggle.removeEventListener("click", oldHandler);

    const handler = () => {
      const current = document.documentElement.classList.contains("light") ? "light" : "dark";
      applyTheme(current === "light" ? "dark" : "light");
    };

    toggle._themeHandler = handler;
    toggle.addEventListener("click", handler);
  }

  // Carga inicial
  initToggle();

  // Cada navegación con View Transitions
  document.addEventListener("astro:page-load", initToggle);
</script>